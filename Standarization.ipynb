   "source": [
    "X_train,X_test,y_train,y_test = train_test_split(df.drop(\"Purchased\",axis=1), # we remove the purchased column becuase we dont want our model know the value of output\n",
    "                                                 df[\"Purchased\"], # we capture the purchased column and we select test size 0.3 and chose random state = 0 \n",
    "                                                 test_size = 0.3,\n",
    "                                                 random_state = 0)\n",
    "\n",
    "X_train.shape,X_test.shape # 280 per hamara model train hoga or 120 jo ha testing data hoga"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "85e1ba34-adf3-461a-a261-3b57543a180a",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "scaler = StandardScaler()\n",
    "\n",
    "scaler.fit(X_train) # means we are calculating the mean and standard deviation fitting the scaler to train the parameters \n",
    "\n",
    "# transform train and test data\n",
    "\n",
    "X_train_Scaled = scaler.transform(X_train)\n",
    "X_test_Scaled = scaler.transform(X_test)"
   ]
